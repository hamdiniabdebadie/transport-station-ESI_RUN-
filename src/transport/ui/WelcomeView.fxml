<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="transport.control.WelcomeController"
            prefHeight="600.0" prefWidth="800.0">
    <top>
        <VBox alignment="CENTER" spacing="20.0" style="-fx-background-color: #336699;">
            <padding>
                <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
            </padding>
            <Label text="ESI-RUN Transport System" textFill="WHITE">
                <font>
                    <Font name="System Bold" size="24.0"/>
                </font>
            </Label>
        </VBox>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="20.0">
            <padding>
                <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
            </padding>

            <Label text="Bienvenue dans le système de transport ESI-RUN">
                <font>
                    <Font size="18.0"/>
                </font>
            </Label>

            <HBox alignment="CENTER" spacing="20.0">
                <Button text="Ajouter un utilisateur" onAction="#handleAddUser" prefWidth="200.0"/>
                <Button text="Acheter un titre de transport" onAction="#handleBuyFareMedium" prefWidth="200.0"/>
            </HBox>

            <HBox alignment="CENTER" spacing="20.0">
                <Button text="Afficher les titres de transport" onAction="#handleDisplayFareMedia" prefWidth="200.0"/>
                <Button text="Valider un titre de transport" onAction="#handleValidateFareMedium" prefWidth="200.0"/>
            </HBox>

            <HBox alignment="CENTER" spacing="20.0">
                <Button text="Système de réclamations" onAction="#handleComplaintSystem" prefWidth="200.0"/>
            </HBox>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" style="-fx-background-color: #f0f0f0;">
            <padding>
                <Insets top="10.0" right="10.0" bottom="10.0" left="10.0"/>
            </padding>
            <Label text="© 2023 ESI-RUN Transport System"/>
        </HBox>
    </bottom>
</BorderPane>
