<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="transport.control.DisplayFareMediaController"
            prefHeight="768.0" prefWidth="1024.0">

    <!-- Left Sidebar -->
    <left>
        <VBox styleClass="sidebar" prefWidth="200" spacing="10">
            <padding>
                <Insets top="20" right="10" bottom="20" left="10"/>
            </padding>

            <Label text="ESI-RUN" styleClass="sidebar-title"/>
            <Label text="Transport System" styleClass="sidebar-subtitle"/>

            <Separator/>

            <Button text="Tableau de bord" styleClass="sidebar-button" onAction="#handleHome"/>
            <Button text="Utilisateurs" styleClass="sidebar-button" onAction="#handleUsers"/>
            <Button text="Titres" styleClass="sidebar-button, active-nav" onAction="#handleFareMedia"/>
            <Button text="Validation" styleClass="sidebar-button" onAction="#handleValidation"/>
            <Button text="Réclamations" styleClass="sidebar-button" onAction="#handleComplaints"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Separator/>
            <Button text="Déconnexion" styleClass="sidebar-button"/>
        </VBox>
    </left>

    <!-- Main Content -->
    <center>
        <VBox spacing="20" style="-fx-padding: 20px;">
            <HBox alignment="CENTER_LEFT" spacing="20">
                <Label text="Liste des titres de transport" styleClass="section-title">
                    <font>
                        <Font name="System Bold" size="24.0"/>
                    </font>
                </Label>

                <Region HBox.hgrow="ALWAYS" />

                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Label text="Filtrer par type:"/>
                    <ComboBox fx:id="filterCombo" prefWidth="150"/>
                    <TextField fx:id="searchField" promptText="Rechercher par ID..." prefWidth="200"/>
                    <Button text="Rafraîchir" onAction="#handleRefresh"/>
                    <Button text="Acheter un titre" onAction="#handleBuyFareMedium"/>
                </HBox>
            </HBox>

            <!-- Fare Media Table -->
            <TableView fx:id="fareMediaTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="idColumn" text="ID" prefWidth="80"/>
                    <TableColumn fx:id="typeColumn" text="Type" prefWidth="120"/>
                    <TableColumn fx:id="dateColumn" text="Date d'achat" prefWidth="150"/>
                    <TableColumn fx:id="prixColumn" text="Prix (DA)" prefWidth="100"/>
                    <TableColumn fx:id="validiteColumn" text="Validité" prefWidth="150"/>
                    <TableColumn fx:id="detailsColumn" text="Détails" prefWidth="300"/>
                    <TableColumn fx:id="actionsColumn" text="Actions" prefWidth="100"/>
                </columns>
            </TableView>

            <!-- Fare Media Details Panel (Initially Hidden) -->
            <VBox fx:id="fareMediaDetailsPanel" visible="false" managed="false" styleClass="card" spacing="10">
                <Label text="Détails du titre de transport" styleClass="card-title"/>

                <GridPane hgap="15" vgap="10">
                    <columnConstraints>
                        <ColumnConstraints minWidth="100" prefWidth="150"/>
                        <ColumnConstraints minWidth="200" prefWidth="300"/>
                    </columnConstraints>

                    <Label text="ID:" GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="form-label"/>
                    <Label fx:id="detailIdLabel" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                    <Label text="Type:" GridPane.columnIndex="0" GridPane.rowIndex="1" styleClass="form-label"/>
                    <Label fx:id="detailTypeLabel" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                    <Label text="Date d'achat:" GridPane.columnIndex="0" GridPane.rowIndex="2" styleClass="form-label"/>
                    <Label fx:id="detailDateLabel" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                    <Label text="Prix:" GridPane.columnIndex="0" GridPane.rowIndex="3" styleClass="form-label"/>
                    <Label fx:id="detailPrixLabel" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                    <Label text="Validité:" GridPane.columnIndex="0" GridPane.rowIndex="4" styleClass="form-label"/>
                    <Label fx:id="detailValiditeLabel" GridPane.columnIndex="1" GridPane.rowIndex="4"/>

                    <Label fx:id="detailProprietaireTitle" text="Propriétaire:" visible="false"
                           GridPane.columnIndex="0" GridPane.rowIndex="5" styleClass="form-label"/>
                    <Label fx:id="detailProprietaireLabel" visible="false"
                           GridPane.columnIndex="1" GridPane.rowIndex="5"/>

                    <Label fx:id="detailTypeCarteTitle" text="Type de carte:" visible="false"
                           GridPane.columnIndex="0" GridPane.rowIndex="6" styleClass="form-label"/>
                    <Label fx:id="detailTypeCarteLabel" visible="false"
                           GridPane.columnIndex="1" GridPane.rowIndex="6"/>
                </GridPane>

                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Button text="Valider ce titre" onAction="#handleValidateSelected" styleClass="button"/>
                    <Button text="Fermer" onAction="#handleCloseDetails" styleClass="button-secondary"/>
                </HBox>
            </VBox>
        </VBox>
    </center>

    <!-- Footer -->
    <bottom>
        <HBox styleClass="footer" alignment="CENTER">
            <Label text="© 2023 ESI-RUN Transport System - Tous droits réservés" styleClass="footer-text"/>
        </HBox>
    </bottom>
</BorderPane>
