<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="transport.control.AddUserController"
            prefHeight="768.0" prefWidth="1024.0">

    <!-- Left Sidebar -->
    <left>
        <VBox styleClass="sidebar" prefWidth="200" spacing="10">
            <padding>
                <Insets top="20" right="10" bottom="20" left="10"/>
            </padding>

            <Label text="ESI-RUN" styleClass="sidebar-title"/>
            <Label text="Transport System" styleClass="sidebar-subtitle"/>

            <Separator/>

            <Button text="Tableau de bord" styleClass="sidebar-button" onAction="#handleHome"/>
            <Button text="Utilisateurs" styleClass="sidebar-button, active-nav" onAction="#handleUsers"/>
            <Button text="Titres" styleClass="sidebar-button" onAction="#handleFareMedia"/>
            <Button text="Validation" styleClass="sidebar-button" onAction="#handleValidation"/>
            <Button text="Réclamations" styleClass="sidebar-button" onAction="#handleComplaints"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Separator/>
            <Button text="Déconnexion" styleClass="sidebar-button"/>
        </VBox>
    </left>

    <!-- Main Content -->
    <center>
        <VBox styleClass="content-area" spacing="20">
            <padding>
                <Insets top="30" right="30" bottom="30" left="30"/>
            </padding>

            <Label text="Informations de l'utilisateur" styleClass="section-title"/>

            <HBox alignment="CENTER" spacing="20">
                <RadioButton fx:id="usagerRadio" text="Usager" selected="true" toggleGroup="$userType"/>
                <RadioButton fx:id="employeRadio" text="Employé" toggleGroup="$userType"/>
                <fx:define>
                    <ToggleGroup fx:id="userType"/>
                </fx:define>
            </HBox>

            <GridPane hgap="15" vgap="15" styleClass="form-container">
                <columnConstraints>
                    <ColumnConstraints minWidth="150" prefWidth="200"/>
                    <ColumnConstraints minWidth="300" prefWidth="400"/>
                </columnConstraints>

                <Label text="Nom:" GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="form-label"/>
                <TextField fx:id="nomField" GridPane.columnIndex="1" GridPane.rowIndex="0" styleClass="text-field"/>
                <Label fx:id="nomErrorLabel" visible="false" styleClass="validation-message"
                       GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                <Label text="Prénom:" GridPane.columnIndex="0" GridPane.rowIndex="2" styleClass="form-label"/>
                <TextField fx:id="prenomField" GridPane.columnIndex="1" GridPane.rowIndex="2" styleClass="text-field"/>
                <Label fx:id="prenomErrorLabel" visible="false" styleClass="validation-message"
                       GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                <Label text="Date de naissance:" GridPane.columnIndex="0" GridPane.rowIndex="4" styleClass="form-label"/>
                <DatePicker fx:id="dateNaissancePicker" GridPane.columnIndex="1" GridPane.rowIndex="4" styleClass="date-picker"/>
                <Label fx:id="dateErrorLabel" visible="false" styleClass="validation-message"
                       GridPane.columnIndex="1" GridPane.rowIndex="5"/>

                <Label text="Handicapé:" GridPane.columnIndex="0" GridPane.rowIndex="6" styleClass="form-label"/>
                <CheckBox fx:id="handicapCheck" GridPane.columnIndex="1" GridPane.rowIndex="6"/>

                <!-- Employee specific fields -->
                <Label fx:id="matriculeLabel" text="Matricule:" visible="false"
                       GridPane.columnIndex="0" GridPane.rowIndex="7" styleClass="form-label"/>
                <TextField fx:id="matriculeField" visible="false"
                           GridPane.columnIndex="1" GridPane.rowIndex="7" styleClass="text-field"/>
                <Label fx:id="matriculeErrorLabel" visible="false" styleClass="validation-message"
                       GridPane.columnIndex="1" GridPane.rowIndex="8"/>

                <Label fx:id="fonctionLabel" text="Fonction:" visible="false"
                       GridPane.columnIndex="0" GridPane.rowIndex="9" styleClass="form-label"/>
                <ComboBox fx:id="fonctionCombo" visible="false"
                          GridPane.columnIndex="1" GridPane.rowIndex="9" styleClass="combo-box"/>
            </GridPane>

            <HBox alignment="CENTER" spacing="20">
                <Button text="Ajouter" onAction="#handleAddUser" styleClass="button"/>
                <Button text="Annuler" onAction="#handleCancel" styleClass="button-secondary"/>
            </HBox>

            <Label fx:id="resultLabel" styleClass="status-success" alignment="CENTER" textAlignment="CENTER" wrapText="true"/>
        </VBox>
    </center>

    <!-- Footer -->
    <bottom>
        <HBox styleClass="footer" alignment="CENTER">
            <Label text="© 2023 ESI-RUN Transport System - Tous droits réservés" styleClass="footer-text"/>
        </HBox>
    </bottom>
</BorderPane>
