<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="transport.control.UsersController"
            prefHeight="768.0" prefWidth="1024.0">

    <!-- Top Header (Same as Dashboard) -->
    <top>
        <VBox styleClass="header">
            <HBox alignment="CENTER_LEFT" spacing="15">
                <VBox>
                    <Label text="ESI-RUN Transport System" styleClass="header-title"/>
                    <Label text="Gestion des utilisateurs" styleClass="header-subtitle"/>
                </VBox>
                <HBox alignment="CENTER_RIGHT" spacing="10" HBox.hgrow="ALWAYS">
                    <Button text="Accueil" styleClass="nav-button" onAction="#handleHome"/>
                    <Button text="Utilisateurs" styleClass="nav-button" onAction="#handleUsers"/>
                    <Button text="Titres" styleClass="nav-button" onAction="#handleFareMedia"/>
                    <Button text="Validation" styleClass="nav-button" onAction="#handleValidation"/>
                    <Button text="Réclamations" styleClass="nav-button" onAction="#handleComplaints"/>
                </HBox>
            </HBox>
        </VBox>
    </top>

    <!-- Main Content -->
    <center>
        <VBox spacing="20" style="-fx-padding: 20px;">
            <HBox alignment="CENTER_LEFT" spacing="20">
                <Label text="Liste des utilisateurs" styleClass="section-title">
                    <font>
                        <Font name="System Bold" size="24.0"/>
                    </font>
                </Label>

                <Region HBox.hgrow="ALWAYS" />

                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Label text="Filtrer:"/>
                    <ComboBox fx:id="filterCombo" prefWidth="150"/>
                    <TextField fx:id="searchField" promptText="Rechercher..." prefWidth="200"/>
                    <Button text="Ajouter un utilisateur" onAction="#handleAddUser"/>
                </HBox>
            </HBox>

            <!-- Users Table -->
            <TableView fx:id="usersTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="idColumn" text="ID" prefWidth="80"/>
                    <TableColumn fx:id="nomColumn" text="Nom" prefWidth="150"/>
                    <TableColumn fx:id="prenomColumn" text="Prénom" prefWidth="150"/>
                    <TableColumn fx:id="typeColumn" text="Type" prefWidth="100"/>
                    <TableColumn fx:id="ageColumn" text="Âge" prefWidth="80"/>
                    <TableColumn fx:id="handicapColumn" text="Handicap" prefWidth="100"/>
                    <TableColumn fx:id="detailsColumn" text="Détails" prefWidth="200"/>
                    <TableColumn fx:id="actionsColumn" text="Actions" prefWidth="120"/>
                </columns>
            </TableView>

            <!-- User Details Panel (Initially Hidden) -->
            <VBox fx:id="userDetailsPanel" visible="false" managed="false" styleClass="card" spacing="10">
                <Label text="Détails de l'utilisateur" styleClass="card-title"/>

                <GridPane hgap="15" vgap="10">
                    <columnConstraints>
                        <ColumnConstraints minWidth="100" prefWidth="150"/>
                        <ColumnConstraints minWidth="200" prefWidth="300"/>
                    </columnConstraints>

                    <Label text="ID:" GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="form-label"/>
                    <Label fx:id="detailIdLabel" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                    <Label text="Nom:" GridPane.columnIndex="0" GridPane.rowIndex="1" styleClass="form-label"/>
                    <Label fx:id="detailNomLabel" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                    <Label text="Prénom:" GridPane.columnIndex="0" GridPane.rowIndex="2" styleClass="form-label"/>
                    <Label fx:id="detailPrenomLabel" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                    <Label text="Date de naissance:" GridPane.columnIndex="0" GridPane.rowIndex="3" styleClass="form-label"/>
                    <Label fx:id="detailDateNaissanceLabel" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                    <Label text="Âge:" GridPane.columnIndex="0" GridPane.rowIndex="4" styleClass="form-label"/>
                    <Label fx:id="detailAgeLabel" GridPane.columnIndex="1" GridPane.rowIndex="4"/>

                    <Label text="Handicap:" GridPane.columnIndex="0" GridPane.rowIndex="5" styleClass="form-label"/>
                    <Label fx:id="detailHandicapLabel" GridPane.columnIndex="1" GridPane.rowIndex="5"/>

                    <Label fx:id="detailMatriculeTitle" text="Matricule:" visible="false"
                           GridPane.columnIndex="0" GridPane.rowIndex="6" styleClass="form-label"/>
                    <Label fx:id="detailMatriculeLabel" visible="false"
                           GridPane.columnIndex="1" GridPane.rowIndex="6"/>

                    <Label fx:id="detailFonctionTitle" text="Fonction:" visible="false"
                           GridPane.columnIndex="0" GridPane.rowIndex="7" styleClass="form-label"/>
                    <Label fx:id="detailFonctionLabel" visible="false"
                           GridPane.columnIndex="1" GridPane.rowIndex="7"/>
                </GridPane>

                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Button text="Fermer" onAction="#handleCloseDetails"/>
                </HBox>
            </VBox>
        </VBox>
    </center>

    <!-- Footer -->
    <bottom>
        <HBox styleClass="footer" alignment="CENTER">
            <Label text="© 2023 ESI-RUN Transport System - Tous droits réservés" styleClass="footer-text"/>
        </HBox>
    </bottom>
</BorderPane>
