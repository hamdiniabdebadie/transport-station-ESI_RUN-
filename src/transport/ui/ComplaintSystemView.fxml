<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="transport.control.ComplaintSystemController"
            prefHeight="768.0" prefWidth="1024.0">

    <!-- Left Sidebar -->
    <left>
        <VBox styleClass="sidebar" prefWidth="200" spacing="10">
            <padding>
                <Insets top="20" right="10" bottom="20" left="10"/>
            </padding>

            <Label text="ESI-RUN" styleClass="sidebar-title"/>
            <Label text="Transport System" styleClass="sidebar-subtitle"/>

            <Separator/>

            <Button text="Tableau de bord" styleClass="sidebar-button" onAction="#handleHome"/>
            <Button text="Utilisateurs" styleClass="sidebar-button" onAction="#handleUsers"/>
            <Button text="Titres" styleClass="sidebar-button" onAction="#handleFareMedia"/>
            <Button text="Validation" styleClass="sidebar-button" onAction="#handleValidation"/>
            <Button text="Réclamations" styleClass="sidebar-button, active-nav" onAction="#handleComplaints"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Separator/>
            <Button text="Déconnexion" styleClass="sidebar-button"/>
        </VBox>
    </left>

    <!-- Main Content -->
    <center>
        <TabPane>
            <Tab text="Soumettre une réclamation">
                <VBox spacing="20" style="-fx-padding: 20px;">
                    <Label text="Nouvelle réclamation" styleClass="section-title">
                        <font>
                            <Font name="System Bold" size="24.0"/>
                        </font>
                    </Label>

                    <HBox spacing="20">
                        <VBox styleClass="card" spacing="15" prefWidth="400">
                            <padding>
                                <Insets top="20" right="20" bottom="20" left="20"/>
                            </padding>

                            <Label text="Informations de la réclamation" styleClass="card-title"/>

                            <VBox spacing="10">
                                <Label text="Utilisateur:" styleClass="form-label"/>
                                <ComboBox fx:id="personneCombo" prefWidth="300"/>
                            </VBox>

                            <VBox spacing="10">
                                <Label text="Type de réclamation:" styleClass="form-label"/>
                                <ComboBox fx:id="typeReclamationCombo" prefWidth="300"/>
                            </VBox>

                            <VBox spacing="10">
                                <Label text="Cible:" styleClass="form-label"/>
                                <HBox spacing="10">
                                    <RadioButton fx:id="stationRadio" text="Station" selected="true" toggleGroup="$targetType"/>
                                    <RadioButton fx:id="transportRadio" text="Moyen de transport" toggleGroup="$targetType"/>
                                    <fx:define>
                                        <ToggleGroup fx:id="targetType"/>
                                    </fx:define>
                                </HBox>
                            </VBox>

                            <VBox spacing="10">
                                <Label text="Sélectionner la cible:" styleClass="form-label"/>
                                <ComboBox fx:id="cibleCombo" prefWidth="300"/>
                            </VBox>
                        </VBox>

                        <VBox styleClass="card" spacing="15" HBox.hgrow="ALWAYS">
                            <padding>
                                <Insets top="20" right="20" bottom="20" left="20"/>
                            </padding>

                            <Label text="Description du problème" styleClass="card-title"/>

                            <TextArea fx:id="descriptionArea" prefHeight="200" wrapText="true" promptText="Décrivez votre problème en détail..."/>

                            <HBox alignment="CENTER_RIGHT" spacing="10">
                                <Button text="Annuler" onAction="#handleClear" styleClass="button-secondary"/>
                                <Button text="Soumettre" onAction="#handleSubmitComplaint" styleClass="button"/>
                            </HBox>

                            <Label fx:id="submitResultLabel" styleClass="status-success"/>
                        </VBox>
                    </HBox>
                </VBox>
            </Tab>

            <Tab text="Liste des réclamations">
                <VBox spacing="20" style="-fx-padding: 20px;">
                    <HBox alignment="CENTER_LEFT" spacing="20">
                        <Label text="Réclamations" styleClass="section-title">
                            <font>
                                <Font name="System Bold" size="24.0"/>
                            </font>
                        </Label>

                        <Region HBox.hgrow="ALWAYS" />

                        <Button text="Rafraîchir" onAction="#handleRefreshComplaints"/>
                    </HBox>

                    <TableView fx:id="complaintsTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="numeroColumn" text="Numéro" prefWidth="80"/>
                            <TableColumn fx:id="dateColumn" text="Date" prefWidth="120"/>
                            <TableColumn fx:id="typeColumn" text="Type" prefWidth="120"/>
                            <TableColumn fx:id="cibleColumn" text="Cible" prefWidth="150"/>
                            <TableColumn fx:id="personneColumn" text="Soumis par" prefWidth="150"/>
                            <TableColumn fx:id="descriptionColumn" text="Description" prefWidth="300"/>
                            <TableColumn fx:id="actionsColumn" text="Actions" prefWidth="80"/>
                        </columns>
                    </TableView>

                    <VBox fx:id="warningBox" visible="false" styleClass="warning-box" spacing="10">
                        <Label text="AVERTISSEMENT: Suspensions" styleClass="warning-title"/>
                        <Label fx:id="warningLabel" wrapText="true"/>
                    </VBox>
                </VBox>
            </Tab>
        </TabPane>
    </center>

    <!-- Footer -->
    <bottom>
        <HBox styleClass="footer" alignment="CENTER">
            <Label text="© 2023 ESI-RUN Transport System - Tous droits réservés" styleClass="footer-text"/>
        </HBox>
    </bottom>
</BorderPane>
